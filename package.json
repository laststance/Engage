{
  "name": "engage",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:e2e": "E2E_TEST=true NODE_ENV=production REACT_NATIVE_NO_DEVTOOLS=1 npx expo run:ios --configuration Release",
    "build:e2e:clean": "pkill -f 'expo run:ios' || true; pnpm test:e2e:clean",
    "build:e2e:restart": "pnpm build:e2e:clean && pnpm build:e2e",
    "test:e2e:clean": "lsof -ti :8097 | xargs -r kill; pkill -f 'react-devtools' || true; pkill -f 'devtools' || true",
    "test:e2e:production": "maestro test maestro/ios/",
    "test:e2e:production:single": "maestro test",
    "test:e2e:ios": "pnpm test:e2e:clean && maestro test maestro/ios/",
    "test:e2e:android": "echo 'Android tests not implemented yet. Run: pnpm test:e2e:ios'",
    "deploy": "node scripts/deploy.js",
    "deploy:check": "node scripts/deploy.js check",
    "deploy:test": "node scripts/deploy.js test",
    "deploy:version": "node scripts/deploy.js version",
    "deploy:build": "node scripts/deploy.js build",
    "deploy:build:ios": "node scripts/deploy.js build:ios",
    "deploy:build:android": "node scripts/deploy.js build:android",
    "deploy:submit": "node scripts/deploy.js submit",
    "deploy:submit:ios": "node scripts/deploy.js submit:ios",
    "deploy:submit:android": "node scripts/deploy.js submit:android",
    "deploy:full": "node scripts/deploy.js deploy",
    "clean": "rm -rf node_modules pnpm-lock.yaml .expo ios android coverage dist"
  },
  "dependencies": {
    "@expo/html-elements": "^55.0.3",
    "@expo/vector-icons": "^15.1.1",
    "@gluestack-ui/core": "^3.0.13",
    "@gluestack-ui/utils": "^3.0.15",
    "@legendapp/motion": "^2.5.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.28",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-document-picker": "^55.0.8",
    "expo-file-system": "^55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-sharing": "^55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-aria": "^3.47.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "0.2.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "react-stately": "^3.45.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-transform-stub": "^2.0.0",
    "jsdom": "^27.4.0",
    "react-native-testing-library": "^6.0.0",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "volta": {
    "node": "22.20.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "@isaacs/brace-expansion": ">=5.0.1"
    },
    "patchedDependencies": {}
  }
}