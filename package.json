{
  "name": "engage",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0",
    "fallow": "pnpm fallow:dead-code && pnpm fallow:dupes",
    "fallow:dead-code": "fallow dead-code --format compact",
    "fallow:dupes": "fallow dupes --format compact --mode mild --min-tokens 90 --min-lines 8 --ignore-imports",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:e2e": "E2E_TEST=true NODE_ENV=production REACT_NATIVE_NO_DEVTOOLS=1 npx expo run:ios --configuration Release",
    "build:e2e:clean": "pkill -f 'expo run:ios' || true; pnpm test:e2e:clean",
    "build:e2e:restart": "pnpm build:e2e:clean && pnpm build:e2e",
    "test:e2e:clean": "lsof -ti :8097 | xargs -r kill; pkill -f 'react-devtools' || true; pkill -f 'devtools' || true",
    "test:e2e:production": "maestro test maestro/ios/",
    "test:e2e:production:single": "maestro test",
    "test:e2e:ios": "pnpm test:e2e:clean && maestro test maestro/ios/",
    "test:e2e:android": "echo 'Android tests not implemented yet. Run: pnpm test:e2e:ios'",
    "deploy": "node scripts/deploy.js",
    "deploy:check": "node scripts/deploy.js check",
    "deploy:test": "node scripts/deploy.js test",
    "deploy:version": "node scripts/deploy.js version",
    "deploy:build": "node scripts/deploy.js build",
    "deploy:build:ios": "node scripts/deploy.js build:ios",
    "deploy:build:android": "node scripts/deploy.js build:android",
    "deploy:submit": "node scripts/deploy.js submit",
    "deploy:submit:ios": "node scripts/deploy.js submit:ios",
    "deploy:submit:android": "node scripts/deploy.js submit:android",
    "deploy:full": "node scripts/deploy.js deploy",
    "clean": "rm -rf node_modules pnpm-lock.yaml .expo ios android coverage dist"
  },
  "dependencies": {
    "@expo/dom-webview": "55.0.6",
    "@expo/metro-runtime": "55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@gluestack-ui/core": "^3.0.19",
    "@gluestack-ui/utils": "^3.0.21",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.1.33",
    "babel-plugin-module-resolver": "^5.0.3",
    "expo": "~55.0.23",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.16",
    "expo-document-picker": "^55.0.13",
    "expo-file-system": "^55.0.19",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-localization": "^55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.14",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~55.0.20",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.17",
    "expo-web-browser": "~55.0.15",
    "i18next": "^26.0.8",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-css-interop": "0.2.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "fallow": "2.64.0",
    "jest": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3"
  },
  "private": true,
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "volta": {
    "node": "22.20.0"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "@xmldom/xmldom@>=0.8.0 <0.8.13": "0.8.13",
      "brace-expansion@<1.1.13": "1.1.14",
      "brace-expansion@>=2.0.0 <2.0.3": "2.1.0",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "flatted@<=3.4.1": "3.4.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=8.0.0 <8.0.6": "8.0.6",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "node-forge@<1.4.0": "1.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.14",
      "tar": ">=7.5.7",
      "yaml@>=2.0.0 <2.8.3": "2.8.4"
    },
    "patchedDependencies": {
      "react-native-css-interop@0.2.2": "patches/react-native-css-interop@0.2.2.patch"
    },
    "onlyBuiltDependencies": [
      "fallow"
    ]
  }
}
